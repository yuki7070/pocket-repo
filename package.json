{
  "name": "pocket-repo",
  "version": "0.1.17",
  "description": "Local read-only Git repository viewer for mobile browsers — files, diffs, worktrees, and agent sessions.",
  "type": "module",
  "packageManager": "pnpm@11.1.1",
  "bin": {
    "pocket-repo": "bin/pocket-repo.mjs"
  },
  "files": [
    "bin",
    ".next/standalone"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "author": "Yuki Tomori",
  "homepage": "https://github.com/yuki7070/pocket-repo#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yuki7070/pocket-repo.git"
  },
  "bugs": {
    "url": "https://github.com/yuki7070/pocket-repo/issues"
  },
  "keywords": [
    "git",
    "repository",
    "viewer",
    "read-only",
    "mobile",
    "worktree",
    "cli"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:pkg": "next build && node scripts/copy-standalone-assets.mjs",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build:pkg"
  },
  "devDependencies": {
    "@base-ui/react": "^1.5.0",
    "@eslint/eslintrc": "^3.3.5",
    "@marp-team/marp-core": "^4.3.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^9.28.0",
    "eslint-config-next": "^15.3.3",
    "hono": "^4.7.11",
    "lucide-react": "^0.468.0",
    "next": "^15.3.3",
    "postcss": "^8.5.15",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp",
      "unrs-resolver"
    ]
  }
}
