:root {
  color-scheme: dark;
  --canvas-default: #0d1117;
  --canvas-overlay: #161b22;
  --canvas-subtle: #010409;
  --border-default: #30363d;
  --border-muted: #21262d;
  --fg-default: #e6edf3;
  --fg-muted: #8b949e;
  --fg-subtle: #6e7681;
  --accent-fg: #2f81f7;
  --success-fg: #3fb950;
  --danger-fg: #f85149;
  --sidebar-bg: #05070a;
  --sidebar-hover: #151b23;
}

* {
  box-sizing: border-box;
}

html,
body {
  min-height: 100%;
}

body {
  margin: 0;
  background: var(--canvas-default);
  color: var(--fg-default);
  font-family:
    -apple-system, BlinkMacSystemFont, "Segoe UI", "Noto Sans", Helvetica,
    Arial, sans-serif, "Apple Color Emoji", "Segoe UI Emoji";
  font-size: 14px;
}

button,
input {
  font: inherit;
}

button {
  cursor: pointer;
}

.app-shell {
  display: grid;
  min-height: 100vh;
  grid-template-columns: 292px minmax(0, 1fr);
  background: var(--canvas-default);
}

.app-sidebar {
  position: sticky;
  top: 0;
  z-index: 30;
  display: grid;
  height: 100vh;
  grid-template-rows: auto minmax(0, 1fr);
  border-right: 1px solid var(--border-muted);
  background: var(--sidebar-bg);
}

.sidebar-header {
  display: flex;
  min-height: 56px;
  align-items: center;
  justify-content: space-between;
  gap: 12px;
  padding: 12px;
}

.brand {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 10px;
  color: var(--fg-default);
  font-weight: 600;
}

.brand-mark {
  display: grid;
  width: 28px;
  height: 28px;
  place-items: center;
  color: var(--fg-default);
}

.sidebar-scroll {
  min-height: 0;
  overflow-y: auto;
  padding: 0 10px 16px;
}

.new-repository-button {
  display: flex;
  width: 100%;
  min-height: 38px;
  align-items: center;
  justify-content: center;
  border: 1px solid var(--border-default);
  border-radius: 8px;
  background: var(--sidebar-hover);
  color: var(--fg-default);
  padding: 8px 10px;
  font-weight: 600;
}

.new-repository-button:hover {
  background: #21262d;
}

.sidebar-section {
  display: grid;
  gap: 8px;
  padding: 10px 0;
}

.sidebar-section + .sidebar-section {
  border-top: 1px solid var(--border-muted);
}

.sidebar-section-title {
  padding: 0 8px;
  color: var(--fg-muted);
  font-size: 12px;
  font-weight: 600;
  text-transform: uppercase;
}

.directory-browser {
  display: grid;
  gap: 8px;
}

.directory-current {
  display: grid;
  grid-template-columns: 30px minmax(0, 1fr);
  gap: 6px;
  align-items: center;
  padding: 0 4px;
}

.directory-current span {
  overflow: hidden;
  color: var(--fg-default);
  font-weight: 600;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.directory-back,
.icon-button {
  display: inline-grid;
  width: 32px;
  height: 32px;
  place-items: center;
  border: 0;
  border-radius: 8px;
  background: transparent;
  color: var(--fg-muted);
}

.directory-back:hover,
.icon-button:hover {
  background: var(--sidebar-hover);
  color: var(--fg-default);
}

.directory-back:disabled {
  cursor: default;
  opacity: 0.35;
}

.open-current-button {
  display: inline-flex;
  min-height: 34px;
  align-items: center;
  justify-content: center;
  gap: 6px;
  border: 1px solid rgba(46, 160, 67, 0.45);
  border-radius: 8px;
  background: #238636;
  color: #ffffff;
  padding: 6px 10px;
  font-weight: 600;
}

.open-current-button:disabled {
  cursor: default;
  border-color: var(--border-default);
  background: #21262d;
  color: var(--fg-subtle);
}

.directory-list,
.sidebar-repo-list {
  display: grid;
  gap: 2px;
}

.directory-item,
.sidebar-repo-item {
  display: grid;
  width: 100%;
  min-height: 36px;
  align-items: center;
  border: 0;
  border-radius: 8px;
  background: transparent;
  color: var(--fg-default);
  padding: 8px;
  text-align: left;
}

.directory-item {
  grid-template-columns: 20px minmax(0, 1fr) auto;
  gap: 8px;
}

.directory-item:hover,
.sidebar-repo-item:hover,
.sidebar-repo-item.active {
  background: var(--sidebar-hover);
}

.directory-item span,
.sidebar-repo-item strong,
.sidebar-repo-item small {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.directory-item em {
  border: 1px solid var(--border-default);
  border-radius: 999px;
  color: var(--success-fg);
  padding: 1px 6px;
  font-size: 11px;
  font-style: normal;
}

.sidebar-repo-item {
  gap: 3px;
}

.sidebar-repo-item strong {
  color: var(--fg-default);
  font-size: 14px;
  font-weight: 500;
}

.sidebar-repo-item small {
  color: var(--fg-muted);
  font-size: 12px;
}

.sidebar-empty {
  border: 1px dashed var(--border-default);
  border-radius: 8px;
  color: var(--fg-muted);
  padding: 10px;
  font-size: 13px;
}

.sidebar-scrim {
  display: none;
}

.modal-scrim {
  position: fixed;
  inset: 0;
  z-index: 50;
  display: grid;
  place-items: center;
  background: rgba(1, 4, 9, 0.72);
  padding: 18px;
}

.repository-modal {
  display: grid;
  width: min(640px, 100%);
  max-height: min(760px, calc(100vh - 36px));
  grid-template-rows: auto minmax(0, 1fr) auto;
  gap: 14px;
  overflow: hidden;
  border: 1px solid var(--border-default);
  border-radius: 12px;
  background: var(--canvas-overlay);
  box-shadow: 0 24px 80px rgba(0, 0, 0, 0.48);
  padding: 16px;
}

.modal-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
}

.modal-header h2 {
  margin: 0;
  color: var(--fg-default);
  font-size: 18px;
}

.modal-header p {
  margin: 4px 0 0;
  color: var(--fg-muted);
}

.repository-modal .directory-browser {
  min-height: 0;
}

.repository-modal .directory-list {
  min-height: 0;
  overflow-y: auto;
  border: 1px solid var(--border-muted);
  border-radius: 8px;
  padding: 6px;
}

.app-content {
  min-width: 0;
}

.topbar {
  display: flex;
  min-height: 56px;
  align-items: center;
  justify-content: space-between;
  gap: 16px;
  border-bottom: 1px solid var(--border-muted);
  background: var(--canvas-subtle);
  padding: 12px 16px;
}

.global-search {
  display: flex;
  width: min(520px, 42vw);
  min-height: 32px;
  align-items: center;
  border: 1px solid var(--border-default);
  border-radius: 6px;
  background: var(--canvas-subtle);
  color: var(--fg-subtle);
  padding: 5px 12px;
  font-size: 14px;
}

.status-pill,
.gh-counter {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  white-space: nowrap;
  border: 1px solid var(--border-default);
  border-radius: 2em;
  padding: 3px 8px;
  color: var(--fg-muted);
  font-size: 12px;
  font-weight: 500;
}

.status-dot {
  width: 8px;
  height: 8px;
  border-radius: 999px;
  background: var(--success-fg);
}

.main {
  width: 100%;
}

.repo-header {
  display: grid;
  gap: 8px;
  border-bottom: 1px solid var(--border-default);
  background: var(--canvas-overlay);
  padding: 16px max(16px, calc((100vw - 292px - 1280px) / 2 + 16px)) 0;
}

.repo-title-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12px;
}

.repo-title {
  display: flex;
  min-width: 0;
  flex-wrap: wrap;
  align-items: center;
  gap: 4px;
  color: var(--fg-muted);
  font-size: 20px;
  line-height: 1.5;
}

.repo-title h1 {
  margin: 0;
  color: var(--accent-fg);
  font-size: 20px;
  font-weight: 600;
  line-height: inherit;
}

.repo-owner {
  color: var(--accent-fg);
}

.repo-slash {
  color: var(--fg-muted);
}

.repo-visibility {
  margin-left: 6px;
  border: 1px solid var(--border-default);
  border-radius: 2em;
  padding: 0 7px;
  color: var(--fg-muted);
  font-size: 12px;
  font-weight: 500;
}

.repo-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 8px;
}

.repo-path-line {
  overflow: hidden;
  color: var(--fg-muted);
  font-size: 12px;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tabs {
  display: flex;
  gap: 6px;
  overflow-x: auto;
  margin: 0 max(16px, calc((100vw - 292px - 1280px) / 2 + 16px));
  padding-top: 8px;
}

.tab {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  min-height: 48px;
  border-bottom: 2px solid transparent;
  padding: 0 8px;
  color: var(--fg-muted);
  font-size: 14px;
  white-space: nowrap;
}

.tab.active {
  border-bottom-color: #f78166;
  color: var(--fg-default);
  font-weight: 600;
}

.repo-layout {
  display: grid;
  width: min(1280px, 100%);
  grid-template-columns: minmax(0, 1fr);
  gap: 24px;
  margin: 0 auto;
  padding: 24px 16px 48px;
}

.repo-main {
  display: grid;
  min-width: 0;
  align-content: start;
  gap: 16px;
}

.repo-sidebar {
  display: grid;
  align-content: start;
  gap: 16px;
  min-width: 0;
}

.code-toolbar {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8px;
}

.branch-button,
.gh-button {
  display: inline-flex;
  min-height: 32px;
  align-items: center;
  justify-content: center;
  gap: 6px;
  border: 1px solid var(--border-default);
  border-radius: 6px;
  background: #21262d;
  color: var(--fg-default);
  padding: 5px 12px;
  font-size: 14px;
  font-weight: 500;
}

.branch-button:hover,
.gh-button:hover {
  background: #30363d;
}

.breadcrumb {
  display: flex;
  min-width: 0;
  flex: 1 1 240px;
  align-items: center;
  gap: 2px;
  overflow-x: auto;
  color: var(--fg-muted);
}

.breadcrumb button {
  flex: 0 0 auto;
  border: 0;
  border-radius: 6px;
  background: transparent;
  color: var(--accent-fg);
  padding: 6px 5px;
  font-weight: 600;
}

.breadcrumb button + button::before {
  margin-right: 8px;
  color: var(--fg-muted);
  content: "/";
  font-weight: 400;
}

.breadcrumb button.active {
  color: var(--fg-default);
}

.file-list,
.readme {
  overflow: hidden;
  border: 1px solid var(--border-default);
  border-radius: 6px;
  background: var(--canvas-default);
}

.file-list-header {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 112px;
  gap: 12px;
  border-bottom: 1px solid var(--border-muted);
  background: var(--canvas-overlay);
  padding: 10px 16px;
  color: var(--fg-muted);
  font-size: 12px;
  font-weight: 600;
}

.file-row {
  display: grid;
  width: 100%;
  grid-template-columns: minmax(0, 1fr) 112px;
  gap: 12px;
  align-items: center;
  border: 0;
  border-bottom: 1px solid var(--border-muted);
  background: transparent;
  padding: 9px 16px;
  color: var(--fg-muted);
  text-align: left;
}

.file-row:last-child {
  border-bottom: 0;
}

.file-row:hover {
  background: rgba(177, 186, 196, 0.06);
}

.file-cell-name {
  display: flex;
  min-width: 0;
  align-items: center;
  gap: 8px;
}

.file-cell-name svg {
  flex: 0 0 auto;
  color: var(--fg-muted);
}

.file-name {
  overflow: hidden;
  color: var(--accent-fg);
  font-weight: 600;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.file-badge {
  overflow: hidden;
  color: var(--fg-muted);
  font-size: 12px;
  text-align: right;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.readme-header {
  display: flex;
  align-items: center;
  gap: 8px;
  border-bottom: 1px solid var(--border-muted);
  background: var(--canvas-overlay);
  padding: 10px 16px;
  color: var(--fg-default);
  font-weight: 600;
}

.readme-body {
  padding: 24px 32px;
  color: var(--fg-muted);
  line-height: 1.6;
}

.code-preview {
  max-height: 72vh;
  margin: 0;
  overflow: auto;
  border-radius: 6px;
  background: var(--canvas-default);
  color: var(--fg-default);
  font-family: ui-monospace, SFMono-Regular, "SF Mono", Consolas,
    "Liberation Mono", Menlo, monospace;
  font-size: 12px;
  line-height: 1.55;
}

code,
.code-preview code {
  font-family: ui-monospace, SFMono-Regular, "SF Mono", Consolas,
    "Liberation Mono", Menlo, monospace;
}

code {
  border-radius: 6px;
  background: rgba(110, 118, 129, 0.4);
  color: var(--fg-default);
  padding: 0.2em 0.4em;
  font-size: 85%;
}

.code-preview code {
  display: block;
  min-width: max-content;
  background: transparent;
  padding: 0;
  white-space: pre;
}

.markdown-preview {
  color: var(--fg-default);
}

.markdown-preview h1,
.markdown-preview h2,
.markdown-preview h3 {
  margin: 24px 0 16px;
  border-bottom: 1px solid var(--border-muted);
  padding-bottom: 0.3em;
  line-height: 1.25;
}

.markdown-preview h1:first-child,
.markdown-preview h2:first-child,
.markdown-preview h3:first-child {
  margin-top: 0;
}

.markdown-preview p,
.markdown-preview ul,
.markdown-preview ol {
  color: var(--fg-muted);
}

.markdown-preview pre {
  overflow: auto;
  border-radius: 6px;
  background: var(--canvas-overlay);
  padding: 16px;
}

.markdown-preview pre code {
  background: transparent;
  padding: 0;
}

.about-box {
  display: grid;
  gap: 10px;
  border-bottom: 1px solid var(--border-muted);
  padding-bottom: 16px;
}

.about-box h2 {
  margin: 0;
  color: var(--fg-default);
  font-size: 16px;
  font-weight: 600;
}

.about-box p {
  margin: 0;
  color: var(--fg-muted);
  line-height: 1.5;
}

.repo-stats {
  display: grid;
  gap: 8px;
  margin: 4px 0 0;
}

.repo-stats div {
  display: flex;
  gap: 6px;
}

.repo-stats dt {
  color: var(--fg-default);
  font-weight: 600;
}

.repo-stats dd {
  margin: 0;
  color: var(--fg-muted);
}

.form-error {
  margin: 0;
  color: var(--danger-fg);
  font-size: 12px;
}

.empty-state {
  border: 1px dashed var(--border-default);
  border-radius: 6px;
  padding: 16px;
  color: var(--fg-muted);
}

.empty-state.inline {
  margin: 12px;
}

.spin {
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.mobile-only {
  display: none;
}

@media (min-width: 1012px) {
  .repo-layout {
    grid-template-columns: minmax(0, 1fr) 296px;
  }
}

@media (min-width: 861px) {
  .app-shell.sidebar-collapsed {
    grid-template-columns: minmax(0, 1fr);
  }

  .app-shell.sidebar-collapsed .app-sidebar {
    display: none;
  }

  .app-shell.sidebar-collapsed .repo-header {
    padding-right: max(16px, calc((100vw - 1280px) / 2 + 16px));
    padding-left: max(16px, calc((100vw - 1280px) / 2 + 16px));
  }

  .app-shell.sidebar-collapsed .tabs {
    margin-right: max(16px, calc((100vw - 1280px) / 2 + 16px));
    margin-left: max(16px, calc((100vw - 1280px) / 2 + 16px));
  }
}

@media (max-width: 860px) {
  .app-shell {
    grid-template-columns: minmax(0, 1fr);
  }

  .app-sidebar {
    position: fixed;
    left: 0;
    display: grid;
    transform: translateX(-100%);
    width: min(86vw, 320px);
    box-shadow: 16px 0 40px rgba(0, 0, 0, 0.45);
    transition: transform 160ms ease;
  }

  .app-sidebar.open {
    transform: translateX(0);
  }

  .sidebar-scrim.open {
    position: fixed;
    inset: 0;
    z-index: 20;
    display: block;
    background: rgba(1, 4, 9, 0.62);
  }

  .mobile-only {
    display: inline-grid;
  }

  .global-search {
    display: none;
  }

  .repo-header {
    padding-right: 16px;
    padding-left: 16px;
  }

  .tabs {
    margin-right: 16px;
    margin-left: 16px;
  }

  .repo-title-row {
    display: grid;
  }

  .repo-actions {
    justify-content: flex-start;
  }

  .repo-layout {
    padding-top: 16px;
  }

  .code-toolbar {
    display: grid;
    grid-template-columns: 1fr auto;
  }

  .breadcrumb {
    grid-column: 1 / -1;
    order: 3;
  }

  .file-list-header,
  .file-row {
    grid-template-columns: minmax(0, 1fr) 78px;
    padding-right: 12px;
    padding-left: 12px;
  }

  .readme-body {
    padding: 16px;
  }
}
